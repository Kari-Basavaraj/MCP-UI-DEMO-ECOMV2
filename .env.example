# ── Figma API ─────────────────────────────────────────────────
# Required for all Figma sync commands (pull, push, probe, verify)
FIGMA_ACCESS_TOKEN=figd_your-token-here

# ── Webhook Receiver (local dev) ─────────────────────────────
# These are read by scripts/figma-webhook-receiver.mjs
# Copy this file to .env.local and fill in real values

# Passcode set when registering the Figma webhook
FIGMA_WEBHOOK_PASSCODE=your-webhook-passcode

# GitHub PAT with repo scope (for repository_dispatch)
GITHUB_TOKEN=ghp_your-token-here

# GitHub repo in owner/name format
GITHUB_REPO=Kari-Basavaraj/MCP-UI-DEMO-ECOMV2

# Figma file key to filter webhook events
FIGMA_FILE_KEY=dbPjFeLfAFp8Sz9YGPs0CZ

# Webhook receiver port (default: 4848)
# WEBHOOK_PORT=4848
